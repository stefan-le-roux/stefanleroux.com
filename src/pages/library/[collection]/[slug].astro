---
import LayoutBlog from "../../../assets/layouts/LayoutPost.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
	// Fetch both collections
	const [blogPosts, sharePosts] = await Promise.all([getCollection("blog"), getCollection("share")]);

	// Merge all entries with collection marker
	const allEntries = [
		...blogPosts.map((entry) => ({ ...entry, collectionType: "blog" })),
		...sharePosts.map((entry) => ({ ...entry, collectionType: "share" })),
	];

	// Extract headings for each entry
	const headingsData = await Promise.all(
		allEntries.map(async (entry) => {
			const rendered = await render(entry);
			return rendered.headings;
		}),
	);

	// Return paths matching original structure + collection param
	return allEntries.map((entry, index) => ({
		params: {
			collection: entry.collectionType, // NEW: added collection parameter
			slug: entry.data.slug, // Original slug handling preserved
		},
		props: {
			post: entry, // Entry now carries collectionType
			headings: headingsData[index], // Same heading extraction pattern
		},
	}));
}

const { post, headings } = Astro.props;
const { Content } = await render(post);
---

<LayoutBlog frontmatter={post.data} headings={headings}>
	<Content />
</LayoutBlog>
