---
import LayoutDefault from "./LayoutDefault.astro";
import Toc from "../blocks/toc.astro";

import { Image } from "astro:assets";

const { frontmatter, headings } = Astro.props;
---

<LayoutDefault title={frontmatter.title} description={frontmatter.description} image={frontmatter.image?.src}>
	<section>
		<article>
			<header>
				<Image src={frontmatter.image} alt={frontmatter.alt} format="avif" layout="constrained" priority />
				<hgroup>
					<h1>{frontmatter.title}</h1>
					<span>
						<span>Published: </span>
						<time class="block" datetime={frontmatter.pubDate.toISOString().split("T")[0]}>
							{frontmatter.pubDate.toISOString().split("T")[0]}
						</time>
					</span>
				</hgroup>
			</header>
			<aside class="toc">
				<Toc headings={headings} />
			</aside>
			<div class="content prose">
				<slot />
			</div>
		</article>
		<aside class="related">
			<div>
				<h2>Author</h2>
				<hr />
				<div class="author">
					<div class="profile">SR</div>
					<div class="info">
						<address>
							<a href="https://stefanleroux.com">Stefan le Roux</a>
						</address>
						Web developer
					</div>
					<div class="about">
						<p>
							My mission is to level the playing field for small businesses and independent entrepreneurs without the
							overhead of enterprise-level development costs.
						</p>
					</div>
				</div>
			</div>
		</aside>
	</section>
</LayoutDefault>

<style>
	section {
		display: grid;
		grid: "article aside" auto / 5fr 2fr;
		gap: 2rem;
		align-items: start;

		@media (width <= 1400px) {
			& {
				grid:
					"article" auto
					"aside" auto / 1fr;
			}
		}
	}

	article {
		padding-block: 1em;
		padding-inline: 1em;
		background: var(--blockColor);
		border: var(--blockBorder);
		border-radius: var(--borderRadius);
		display: grid;
		grid:
			"head head" auto
			"slot toc" auto / 1fr 300px;
		gap: 2em 1em;

		@media (width <= 1100px) {
			& {
				grid:
					"head" auto
					"toc" auto
					"slot" auto
					"foo" auto / 1fr;
			}
		}
	}

	header {
		grid-area: head;
		display: grid;
		gap: 1em;

		img {
			inline-size: 100%;
			aspect-ratio: 16 / 9;
			object-fit: cover;
			border-radius: var(--borderRadius);
		}

		hgroup {
			display: grid;
			place-items: start;
			gap: 2rem;
			text-transform: uppercase;
			text-wrap: balance;
		}

		span:has(time) {
			font-size: var(--fs-1);
			display: inline-block;
			background: oklch(from var(--colorSuc) l c h / 0.15);
			color: var(--colorSuc);
			border-radius: var(--borderRadius);
			font-variation-settings: "wght" 700;
			padding-inline: 0.3em;
			padding-block: 0.15em;
		}
	}

	.toc {
		grid-area: toc;
		inline-size: min(400px, 100%);
		margin-inline: auto;
	}

	.content {
		:is(h2, h3, h4, h5, h6) {
			scroll-margin-top: calc(1.5lh + 0.5rem);
		}

		h2 {
			font-size: var(--fs-4);
		}

		h3 {
			font-size: var(--fs-3);
		}

		h4 {
			font-size: var(--fs-2);
		}

		code {
			display: inline-block;
			background: black;
			border-radius: 0.25em;
			padding-inline: 0.35em;
			padding-block: 0.125em;
			font-size: var(--fs-0);
		}

		hr {
			margin-block: 1em;
			font-size: var(--fs-4);
			border: unset;
			border-top: dotted 5px;
		}
	}

	.related {
		position: sticky;
		inset: calc(1.5lh + 2rem) auto auto auto;
		padding-block: 1em;
		padding-inline: 1em;
		background: var(--blockColor);
		border: var(--blockBorder);
		border-radius: var(--borderRadius);
		display: grid;
		gap: 4rem;

		hr {
			margin-block: 1rem 2rem;
		}

		.author {
			display: grid;
			grid:
				"profile info" auto
				"about about" auto / auto 1fr;
			place-items: center start;
			gap: 1em;
			font-size: var(--fs-0);

			.profile {
				grid-area: profile;
				inline-size: 64px;
				aspect-ratio: 1;
				object-fit: cover;
				background: oklch(from #02b787 l c h / 0.3);
				border-radius: 50%;
				border: solid 0.15rem oklch(from #02b787 l c h / 1);
				color: oklch(from #02b787 l c h / 1);
				font-size: 3rem;
				text-align: center;
				align-content: center;
			}

			.info {
				address {
					font-size: var(--fs-2);
					font-style: normal;
					font-variation-settings: "wght" 700;
				}
			}

			.about {
				grid-area: about;
				flex: 1 1 60%;
				display: grid;
				gap: 1rem;
			}
		}
	}
</style>
