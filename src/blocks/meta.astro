---
import "../styles/global.css";
import "../styles/icons-breeze.css";

const { title, description, image = "favicon.svg" } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width,initial-scale=1" />
	<meta name="generator" content={Astro.generator} />

	<meta property="og:type" content="website" />
	<meta property="og:url" content={Astro.url} />
	<meta property="og:title" content={title} />
	<meta property="og:description" content={description} />
	<meta property="og:image" content={new URL(image, Astro.url)} />

	<meta name="twitter:card" content="summary_large_image" />
	<meta name="twitter:url" content={Astro.url} />
	<meta name="twitter:title" content={title} />
	<meta name="twitter:description" content={description} />
	<meta name="twitter:image" content={new URL(image, Astro.url)} />

	<link rel="canonical" href={canonicalURL} />
	<link rel="icon" type="image/png" href="/favicon.png" />
	<link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap.xml" />
	<link rel="preload" href="/fonts/space-grotesk_variable-wght.woff2" as="font" type="font/woff2" crossorigin />
	<link rel="preload" href="/fonts/icons-breeze.woff2" as="font" type="font/woff2" crossorigin />
	<link rel="preconnect" href="https://lab.vivtec.co.za" />

	<meta name="description" content={description} />
	<title>{title}</title>
</head>
